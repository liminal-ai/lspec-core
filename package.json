{
  "name": "@lspec/core",
  "version": "0.1.0",
  "description": "Liminal Spec Core SDK / CLI Runtime",
  "type": "module",
	"main": "./dist/sdk/index.js",
	"types": "./dist/sdk/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/sdk/index.d.ts",
			"import": "./dist/sdk/index.js"
		},
		"./sdk": {
			"types": "./dist/sdk/index.d.ts",
			"import": "./dist/sdk/index.js"
		},
		"./sdk/contracts": {
			"types": "./dist/sdk/contracts/index.d.ts",
			"import": "./dist/sdk/contracts/index.js"
		},
		"./sdk/errors": {
			"types": "./dist/sdk/errors/index.d.ts",
			"import": "./dist/sdk/errors/index.js"
		}
	},
	"bin": {
		"lspec": "./dist/bin/lspec.js"
	},
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "format:check": "biome format src tests scripts",
    "format": "biome format --write src tests scripts",
    "lint": "biome lint src tests scripts",
    "check": "biome check src tests scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:test-baseline": "tsx scripts/capture-test-baseline.ts",
    "guard:no-test-changes": "tsx scripts/guard-no-test-changes.ts",
    "build": "tsup && node scripts/ensure-bin-shebang.mjs",
    "pack-and-install-smoke": "tsx scripts/pack-and-install-smoke.ts",
    "red-verify": "npm run format:check && npm run lint && npm run typecheck && npm run capture:test-baseline",
    "verify": "npm run red-verify && npm run test",
    "green-verify": "npm run verify && npm run guard:no-test-changes",
    "verify-all": "npm run verify && echo 'verify-all: integration suite not yet present (Story 4 owns it) — placeholder pass'"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "c12": "^3.3.4",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "pathe": "^2.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.12.2",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "author": "Lee Moore <lee@liminal.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liminal-ai/lspec-core.git"
  },
  "homepage": "https://github.com/liminal-ai/lspec-core#readme",
  "bugs": {
    "url": "https://github.com/liminal-ai/lspec-core/issues"
  },
  "keywords": [
    "liminal-spec",
    "cli",
    "sdk",
    "implementation",
    "runtime"
  ]
}
